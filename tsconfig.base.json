{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@syncslot/slot-engine/*": ["packages/slot-engine/src/*"],
      "@syncslot/database/*": ["packages/database/src/*"],
      "@syncslot/types/*": ["packages/types/src/*"],
      "@syncslot/config/*": ["packages/config/src/*"]
    }
  }
}
